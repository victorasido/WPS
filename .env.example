# Word Signer Bot Configuration Example
# Copy this to .env and fill in the values

# ── Telegram ──
# Get your token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# ── Environment ──
# Choices: development, production
APP_ENV=development

# ── Paths ──
# Directory for database and logs
DATA_DIR=./data


# ── Conversion Queue ──
# Batas maks konversi LibreOffice yang berjalan bersamaan.
# Turunkan ke 1-2 jika server RAM < 2GB, naikkan jika RAM >= 4GB.
MAX_CONVERSIONS=3

# Timeout subprocess LibreOffice dalam detik.
LIBREOFFICE_TIMEOUT=180

# Timeout Telegram API dalam detik.
# Di server/VPS, naikkan CONNECT dan POOL ke 60 jika sering ConnectTimeout.
# READ dan WRITE perlu besar karena file dokumen bisa multi-MB.
TELEGRAM_CONNECT_TIMEOUT=60
TELEGRAM_READ_TIMEOUT=300
TELEGRAM_WRITE_TIMEOUT=300
TELEGRAM_POOL_TIMEOUT=60

# ── Webhook Mode (Opsional, butuh domain publik + SSL) ──
# Ubah ke true untuk mengaktifkan mode webhook (hemat CPU di production)
USE_WEBHOOK=false
# WEBHOOK_URL=https://yourdomain.com/telegram-webhook
# WEBHOOK_PORT=8443
# WEBHOOK_SECRET=random_secret_string_di_sini
